{
	"name": "react-geogebra",
	"version": "1.2.7",
	"description": "A react component to add the GeoGebra Math App to your react project.",
	"homepage": "https://github.com/pfaffmann/react-geogebra/tree/main/react-geogebra#readme",
	"bugs": "https://github.com/pfaffmann/react-geogebra/issues",
	"repository": {
		"type": "git",
		"url": "https://github.com/pfaffmann/react-geogebra",
		"directory": "react-geogebra"
	},
	"license": "MIT",
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": {
			"source": "./src/index.ts",
			"types": "./dist/index.d.ts",
			"require": "./dist/index.cjs",
			"import": "./dist/index.mjs",
			"default": "./dist/index.mjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "pnpm clean && quickbundle build",
		"clean": "rm -rf dist",
		"prepublishOnly": "pnpm build",
		"start": "pnpm watch",
		"test": "vitest --passWithNoTests --typecheck --reporter=verbose",
		"watch": "quickbundle watch"
	},
	"devDependencies": {
		"@types/react": "19.2.14",
		"quickbundle": "2.16.0",
		"react": "19.2.5",
		"vitest": "4.1.5"
	},
	"peerDependencies": {
		"react": "^19.2.5"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org"
	}
}
